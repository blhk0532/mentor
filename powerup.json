{
    "name" : "Mentor",
    "description" : "Mentor AGI–powered Wix application that adds the Mentor AI Assistant to your dashboard.",
    "cover" : "https://raw.githubusercontent.com/blhk0532/mentor/main/_ignore/art/cover.jpg",
    "includes" : [
        "pages", 
        "models", 
        "migrations"
    ],
    "pages" : [
        "pages/blog/index.blade.php",
        "pages/blog/[Post:slug].blade.php"
    ],
    "tables" : [
        "posts"
    ],
    "models" : [
        "App\\Models\\Post"
    ],
    "run_after_install" : {
        "commands" : [
            "migrate"
        ],
        "factories" : [
            {
                "model" : "App\\Models\\Post",
                "count" : "10"
            }
        ]
    }
}
